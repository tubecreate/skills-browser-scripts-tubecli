{
  "name": "Gmail Login with 2FA",
  "slug": "gmail_login_with_2fa",
  "description": "Đăng nhập Google/Gmail với email, password và TOTP 2FA tự động. Dùng như function trong script khác.",
  "category": "general",
  "target_url": "https://accounts.google.com",
  "tags": ["login", "google", "gmail", "2fa"],
  "steps": [
    {
      "type": "navigate",
      "params": {
        "url": "https://www.google.com",
        "description": "Go to Google homepage"
      }
    },
    {
      "type": "sleep",
      "params": {
        "ms": 500,
        "description": "Pause before clicking email field"
      }
    },
    {
      "type": "click",
      "params": {
        "selector": "input[type='email'], input[name='identifier'], #identifierId",
        "description": "Click email input"
      }
    },
    {
      "type": "hover",
      "params": {
        "selector": "input[type='email'], input[name='identifier'], #identifierId",
        "description": "Hover over email input"
      }
    },
    {
      "type": "sleep",
      "params": {
        "ms": 400,
        "description": "Brief pause before typing"
      }
    },
    {
      "type": "type",
      "params": {
        "selector": "input[type='email'], input[name='identifier'], #identifierId",
        "text": "{{email}}",
        "description": "Type email address"
      }
    },
    {
      "type": "sleep",
      "params": {
        "ms": 800,
        "description": "Pause before pressing Next"
      }
    },
    {
      "type": "hover",
      "params": {
        "selector": "#identifierNext button, button[jsname='LgbsSe'], #identifierNext > div > button",
        "description": "Hover over Next button"
      }
    },
    {
      "type": "sleep",
      "params": {
        "ms": 500,
        "description": "Pause before clicking Next"
      }
    },
    {
      "type": "click",
      "params": {
        "selector": "#identifierNext button, button[jsname='LgbsSe'], #identifierNext > div > button",
        "description": "Click Next after email"
      }
    },
    {
      "type": "wait",
      "params": {
        "selector": "input[type='password'], input[name='Passwd'], #password input",
        "timeout": 15000,
        "description": "Wait for password field to appear"
      }
    },
    {
      "type": "sleep",
      "params": {
        "ms": 2000,
        "description": "Pause after email submitted"
      }
    },
    {
      "type": "hover",
      "params": {
        "selector": "input[type='password'], input[name='Passwd'], #password input",
        "description": "Hover over password input"
      }
    },
    {
      "type": "sleep",
      "params": {
        "ms": 500,
        "description": "Pause before clicking password field"
      }
    },
    {
      "type": "click",
      "params": {
        "selector": "input[type='password'], input[name='Passwd'], #password input",
        "description": "Click password input"
      }
    },
    {
      "type": "sleep",
      "params": {
        "ms": 400,
        "description": "Brief pause before typing password"
      }
    },
    {
      "type": "type",
      "params": {
        "selector": "input[type='password'], input[name='Passwd'], #password input",
        "text": "{{password}}",
        "description": "Type password"
      }
    },
    {
      "type": "sleep",
      "params": {
        "ms": 800,
        "description": "Pause before pressing Next"
      }
    },
    {
      "type": "hover",
      "params": {
        "selector": "#passwordNext button, button[jsname='LgbsSe'], #passwordNext > div > button",
        "description": "Hover over password Next button"
      }
    },
    {
      "type": "sleep",
      "params": {
        "ms": 500,
        "description": "Pause before clicking password Next"
      }
    },
    {
      "type": "click",
      "params": {
        "selector": "#passwordNext button, button[jsname='LgbsSe'], #passwordNext > div > button",
        "description": "Click Next after password"
      }
    },
    {
      "type": "sleep",
      "params": {
        "ms": 2000,
        "description": "Wait after submitting password"
      }
    },
    {
      "type": "condition",
      "params": {
        "description": "Check if 2FA input appears"
      }
    },
    {
      "type": "wait",
      "params": {
        "selector": "div[role='main'], .bk, .nH, [aria-label='Inbox'], table[role='grid']",
        "timeout": 30000,
        "description": "Wait for Gmail inbox to load"
      }
    },
    {
      "type": "sleep",
      "params": {
        "ms": 2000,
        "description": "Admire the inbox"
      }
    },
    {
      "type": "screenshot",
      "params": {
        "description": "Take screenshot of inbox"
      }
    }
  ],
  "variables": [],
  "is_function": true,
  "function_inputs": [
    {"name": "email", "type": "string", "required": true, "description": "Gmail/Google email address"},
    {"name": "password", "type": "string", "required": true, "description": "Account password"},
    {"name": "totp_secret", "type": "string", "required": false, "description": "TOTP 2FA secret key (base32). Nếu có sẽ tự nhập mã 2FA."}
  ],
  "function_outputs": [
    {"name": "login_status", "type": "string", "description": "success hoặc failed"}
  ],
  "created_at": "2026-05-05 03:15:17",
  "updated_at": "2026-05-05T12:17:00.000000"
}